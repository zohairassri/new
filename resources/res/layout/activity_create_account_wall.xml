<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/activity_create_account_wall_0"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:background="@color/white"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/header_image"
                android:layout_width="0dp"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:contentDescription="@null"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/bg_create_account_wall_header"/>
            <TextView
                android:textSize="32sp"
                android:textColor="@color/black_1"
                android:id="@+id/title_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/create_account_wall_global_spacing"
                android:text="@string/create_account_wall_title"
                android:fontFamily="@font/slab_regular_bold"
                android:layout_marginStart="@dimen/create_account_wall_global_spacing"
                android:layout_marginEnd="@dimen/create_account_wall_global_spacing"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/header_image"/>
            <TextView
                android:textColor="@color/black_1"
                android:id="@+id/note_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/create_account_wall_global_spacing"
                android:text="@string/create_account_wall_note_title"
                android:layout_marginStart="@dimen/create_account_wall_global_spacing"
                android:layout_marginEnd="@dimen/create_account_wall_global_spacing"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/title_text"
                style="@style/TA.Ath.Headline.Bold"/>
            <View
                android:id="@+id/note_1_dot"
                android:background="@drawable/shape_dot_large"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="7dp"
                app:layout_constraintStart_toStartOf="@+id/note_title"
                app:layout_constraintTop_toTopOf="@+id/note_1_text"/>
            <TextView
                android:textColor="@color/black_1"
                android:id="@+id/note_1_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/create_account_wall_note_1"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="@dimen/create_account_wall_global_spacing"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/note_1_dot"
                app:layout_constraintTop_toBottomOf="@+id/note_title"
                style="@style/TA.Ath.Body1"/>
            <View
                android:id="@+id/note_2_dot"
                android:background="@drawable/shape_dot_large"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="7dp"
                app:layout_constraintStart_toStartOf="@+id/note_title"
                app:layout_constraintTop_toTopOf="@+id/note_2_text"/>
            <TextView
                android:textColor="@color/black_1"
                android:id="@+id/note_2_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/create_account_wall_note_2"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="@dimen/create_account_wall_global_spacing"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/note_2_dot"
                app:layout_constraintTop_toBottomOf="@+id/note_1_text"
                style="@style/TA.Ath.Body1"/>
            <View
                android:id="@+id/note_3_dot"
                android:background="@drawable/shape_dot_large"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="7dp"
                app:layout_constraintStart_toStartOf="@+id/note_title"
                app:layout_constraintTop_toTopOf="@+id/note_3_text"/>
            <TextView
                android:textColor="@color/black_1"
                android:id="@+id/note_3_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/create_account_wall_note_3"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="@dimen/create_account_wall_global_spacing"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/note_3_dot"
                app:layout_constraintTop_toBottomOf="@+id/note_2_text"
                style="@style/TA.Ath.Body1"/>
            <TextView
                android:id="@+id/registration_button"
                android:tag="binding_1"
                android:background="@drawable/button_background_red_rounded"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginTop="@dimen/create_account_wall_global_spacing"
                android:layout_marginBottom="@dimen/create_account_wall_global_spacing"
                android:text="@string/create_account_wall_button_registration"
                android:layout_marginStart="@dimen/create_account_wall_global_spacing"
                android:layout_marginEnd="@dimen/create_account_wall_global_spacing"
                app:layout_constraintBottom_toTopOf="@+id/login_button"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/note_3_text"
                app:layout_constraintVertical_bias="1"
                style="@style/TA.Ath.Button.Dark"/>
            <TextView
                android:textColor="@color/black"
                android:id="@+id/login_button"
                android:tag="binding_2"
                android:background="@drawable/button_background_white_rounded"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginBottom="@dimen/create_account_wall_global_spacing"
                android:text="@string/create_account_wall_button_login"
                android:layout_marginStart="@dimen/create_account_wall_global_spacing"
                android:layout_marginEnd="@dimen/create_account_wall_global_spacing"
                app:layout_constraintBottom_toTopOf="@+id/cancel_button"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                style="@style/TA.Ath.Button.Dark"/>
            <TextView
                android:textColor="@color/black"
                android:id="@+id/cancel_button"
                android:tag="binding_3"
                android:background="@drawable/selector_clickable_item_bg_gray"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginBottom="@dimen/create_account_wall_global_spacing"
                android:text="@string/create_account_wall_button_cancel"
                android:layout_marginStart="@dimen/create_account_wall_global_spacing"
                android:layout_marginEnd="@dimen/create_account_wall_global_spacing"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                style="@style/TA.Ath.Button.Dark"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
