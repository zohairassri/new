<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid
                android:width="3dp"
                android:color="@color/live_room_avatar_border"/>
        </shape>
    </item>
    <item
        android:left="3dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="3dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="@color/ath_grey_62"
                android:endColor="@color/ath_grey_65"
                android:angle="0"
                android:type="radial"
                android:gradientRadius="50%p"/>
        </shape>
    </item>
</layer-list>
